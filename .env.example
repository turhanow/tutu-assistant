TELEGRAM_BOT_TOKEN=
# Local development uses polling. Cloud Run overrides this with webhook.
BOT_TRANSPORT=polling
# Required only for webhook mode, e.g. https://service-project.region.run.app
PUBLIC_BASE_URL=
# Required only for webhook mode; use a random 1-256 character A-Z/a-z/0-9/_/- value.
TELEGRAM_WEBHOOK_SECRET=
PORT=8080
WEBHOOK_MAX_CONNECTIONS=16
WEBHOOK_MAX_BODY_BYTES=1000000
TONE_OF_VOICE_V2_ENABLED=true
CONTROLLED_DELIGHT_ENABLED=true
TUTU_MCP_URL=https://mcp.tutu.ru/mcp
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.6-sol
OPENAI_TIMEOUT_SECONDS=10
DYNAMIC_DISCOVERY_ENABLED=true
DYNAMIC_DISCOVERY_TIMEOUT_SECONDS=30
# Set true only for an explicitly trusted gateway with a dedicated key.
OPENAI_ALLOW_CUSTOM_BASE_URL=false
TUTU_TIMEOUT_SECONDS=12
TUTU_POOL_SIZE=5
SEARCH_TIMEOUT_SECONDS=25
DISCOVERY_VERIFICATION_TIMEOUT_SECONDS=18
DISCOVERY_MAX_CONCURRENCY=5
MAX_CONCURRENT_UPDATES=16
LOG_LEVEL=INFO
APP_TIMEZONE=Europe/Moscow
# Optional override; the default is data/destinations/v1/catalog.json.
# DESTINATION_CATALOG_PATH=/absolute/path/to/catalog.json
ANALYTICS_QUEUE_SIZE=256
ANALYTICS_FLUSH_TIMEOUT_SECONDS=2
# Local SQLite file; var/ is excluded from git.
FEEDBACK_DB_PATH=var/feedback.sqlite3
FEEDBACK_RETENTION_DAYS=30
FEEDBACK_TIMEOUT_SECONDS=2
BOT_KILL_SWITCH=false
DISCOVERY_ENABLED=true
FEEDBACK_ENABLED=true
ANALYTICS_ENABLED=true
PROVIDER_MAX_INFLIGHT=8
PROVIDER_CALLS_PER_MINUTE=120
PROVIDER_CIRCUIT_FAILURE_THRESHOLD=3
PROVIDER_CIRCUIT_RECOVERY_SECONDS=30
